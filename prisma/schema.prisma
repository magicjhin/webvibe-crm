// Webvibe CRM — Prisma schema.
// Iteration 1: User (single admin) + Settings (singleton).
// Iteration 2: Client, Lead, Project, Task + enums.
// See DATABASE.md for the full planned schema and conventions.
//
// Prisma 7 specifics:
//   - URLs live in prisma.config.ts (datasource.url for runtime, migrate.adapter for CLI).
//   - Driver adapters are standard in Prisma 7; no preview flag needed.
//
// Iter 2 scope note: back-relations from Client / Project / Lead to future
// models (Invoice / Contract / Proposal / Payment / Maintenance / Reminder)
// are intentionally omitted here — those models land in Iter 3+. Adding them
// now would break `prisma format` because the target models don't exist yet.
//
// Iter 3 update: Invoice / Payment / Expense added below. Client and Project
// now back-reference Invoice and Payment. Contract / Proposal / Maintenance /
// Reminder are still deferred — Iter 4 and Iter 5 respectively.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------
// User — single admin (ADR-002: no multi-user, no roles).
// ---------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------
// Settings — singleton (id = 1). Brand, numbering, document defaults.
// Created in prisma/seed.ts.
// ---------------------------------------------------------------
model Settings {
  id Int @id @default(1)

  // Brand / requisites
  companyName  String
  ownerName    String
  personalCode String? // Asmens kodas — для §1 ŠALYS договора (Iter 4)
  vatId        String?
  regNumber    String? // Individualios veiklos pažymos Nr.
  address      String
  iban         String
  swift        String?
  bankNote     String? // Свободный текст про банк (например про Wise + Belgija)
  email        String
  phone        String?
  website      String?
  logoUrl      String?
  signatureUrl String?

  // Numbering (ADR-011)
  invoicePrefix   String @default("WV")
  invoiceCounter  Int    @default(0)
  invoicePadding  Int    @default(3)
  contractPrefix  String @default("WVS")
  contractCounter Int    @default(0)
  contractPadding Int    @default(6)
  proposalPrefix  String @default("WVP")
  proposalCounter Int    @default(0)
  proposalPadding Int    @default(3)

  // Currency / language (MVP: single-currency EUR, lt documents — ADR-014)
  defaultCurrency  String @default("EUR")
  documentLanguage String @default("lt")

  // PDF
  pdfFooterNote      String?
  defaultPaymentDays Int     @default(1) // Apmokėti iki = issuedAt + N дней (ADR-025)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------
// Client — individual или company. Owner of leads/projects/...
// Back-relations to invoices/contracts/proposals/payments/maintenance/
// reminders are added in Iter 3+ together with those models.
// ---------------------------------------------------------------
model Client {
  id      String     @id @default(cuid())
  kind    ClientKind @default(individual)
  name    String
  email   String?
  phone   String?
  website String?

  // Реквизиты (для PDF) — заполняются позднее, могут быть пустыми
  vatId                String? // PVM mokėtojo kodas
  regNumber            String? // Įmonės kodas
  address              String?
  representative       String? // "Atstovaujama direktoriaus N" — для §1 договора и бокса счёта
  technicalContactName String? // "Techninis kontaktas: ..." — для бокса счёта

  language String       @default("lt")
  status   ClientStatus @default(active)
  source   String?
  notes    String?

  leads       Lead[]
  projects    Project[]
  invoices    Invoice[]
  payments    Payment[]
  contracts   Contract[]
  proposals   Proposal[]
  maintenance Maintenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([kind])
}

enum ClientKind {
  individual
  company
}

enum ClientStatus {
  active
  archived
}

// ---------------------------------------------------------------
// Lead — pre-client touchpoint. Full UI in Iter 5; defined here
// so Project.convertedFromLeadId FK can compile.
// ---------------------------------------------------------------
model Lead {
  id            String      @id @default(cuid())
  name          String
  company       String?
  contact       String
  task          String
  budget        Decimal?    @db.Decimal(12, 2)
  urgency       LeadUrgency @default(normal)
  source        String?
  status        LeadStatus  @default(new)
  nextContactAt DateTime?
  notes         String?

  // Repeat-leads can reference an existing client; deleting the client
  // detaches the lead but doesn't destroy its history.
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Конверсия в проект
  convertedToProjectId String?
  convertedToProject   Project? @relation("LeadConvertedProject", fields: [convertedToProjectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([nextContactAt])
  @@index([clientId])
  @@index([convertedToProjectId])
}

enum LeadUrgency {
  low
  normal
  high
}

enum LeadStatus {
  new
  to_contact
  discussion
  awaiting_proposal
  proposal_sent
  thinking
  accepted
  declined
  postponed
}

// ---------------------------------------------------------------
// Project — main work unit. Belongs to a Client.
// Stages stored as JSON for flexibility (see DATABASE.md note).
// Tasks cascade-delete with the project.
// ---------------------------------------------------------------
model Project {
  id       String        @id @default(cuid())
  title    String
  clientId String
  client   Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  type     ProjectType
  stack    String?
  status   ProjectStatus @default(idea)

  price    Decimal @default(0) @db.Decimal(12, 2)
  advance  Decimal @default(0) @db.Decimal(12, 2)
  currency String  @default("EUR")

  startedAt   DateTime?
  deadlineAt  DateTime?
  completedAt DateTime?

  // Ссылки (JSON): { github, vercel, figma, drive, site, wpAdmin, prodAdmin, ... }
  links Json?

  // Этапы как чеклист (JSON): [{ name, done, order, dueAt? }]
  stages Json?

  hasMaintenance Boolean @default(false)
  notes          String?

  tasks          Task[]
  leadsConverted Lead[]        @relation("LeadConvertedProject")
  invoices       Invoice[]
  payments       Payment[]
  contracts      Contract[]
  proposals      Proposal[]
  maintenance    Maintenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([deadlineAt])
}

enum ProjectType {
  landing
  website
  corporate
  wordpress
  headless_wp
  nextjs
  crm_dashboard
  booking
  quiz_funnel
  maintenance
  other
}

enum ProjectStatus {
  idea
  estimating
  awaiting_advance
  in_progress
  waiting_client
  review
  revisions
  ready
  paid
  archived
}

// ---------------------------------------------------------------
// Task — inline в карточке проекта, отдельной страницы нет.
// ---------------------------------------------------------------
model Task {
  id          String       @id @default(cuid())
  title       String
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(normal)
  dueAt       DateTime?
  description String?
  checklist   Json? // [{ text, done }]
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([dueAt])
}

enum TaskStatus {
  todo
  in_progress
  waiting_client
  review
  done
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

// ---------------------------------------------------------------
// Invoice + InvoiceItem (Iter 3). Numbering: WV-001, transactional.
// No PVM. Single currency (EUR) per ADR-007/ADR-014.
// ---------------------------------------------------------------
model Invoice {
  id        String      @id @default(cuid())
  number    String      @unique
  kind      InvoiceKind @default(advance)
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId String?
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: Restrict)

  issuedAt DateTime
  dueAt    DateTime?
  status   InvoiceStatus @default(draft)

  currency String  @default("EUR")
  subtotal Decimal @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2) // = subtotal (no PVM)

  // Maintenance idempotency: 'YYYY-MM' for kind=maintenance, null otherwise.
  // Combined with maintenanceId — guarantees one invoice per period
  // even on cron retry / double run (Iter 4: Maintenance model now exists).
  maintenanceId String?
  maintenance   Maintenance? @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  periodKey     String?

  notes  String?
  // Импорт старого счёта: если задано — это загруженный PDF (Vercel Blob),
  // PDF-роут отдаёт ИМЕННО этот файл, а не генерит из шаблона. Переиспользуем
  // существующий столбец (миграция не нужна). Кэш сгенерированных PDF (Phase 2)
  // тут не реализован, так что конфликта нет.
  pdfUrl String?

  items    InvoiceItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([maintenanceId, periodKey])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([dueAt])
  @@index([maintenanceId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  title       String
  description String?
  qty         Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2) // = qty * unitPrice
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
}

enum InvoiceKind {
  advance
  final
  full
  maintenance
}

enum InvoiceStatus {
  draft
  sent
  paid
  cancelled
}

// Note: `overdue` is NOT a stored status — it's derived as
//   status='sent' AND dueAt < now().
// Dashboard and filters compute it on the fly.

// ---------------------------------------------------------------
// Payment (Iter 3). Tracks money received. May or may not link to an invoice.
// ---------------------------------------------------------------
model Payment {
  id        String      @id @default(cuid())
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId String?
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invoiceId String?
  invoice   Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  kind      PaymentKind
  amount    Decimal     @db.Decimal(12, 2)
  currency  String      @default("EUR")
  paidAt    DateTime
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([invoiceId])
  @@index([paidAt])
}

enum PaymentKind {
  advance
  final
  full
  maintenance
  other
}

// ---------------------------------------------------------------
// Expense (Iter 3). Tracks money spent. Optional attached file (Vercel Blob).
// `recurring/recurrence` are storage-only in MVP per ADR-017 — the actual
// recurring expense automation is Phase 2.
// ---------------------------------------------------------------
model Expense {
  id          String          @id @default(cuid())
  category    ExpenseCategory
  vendor      String?
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("EUR")
  occurredAt  DateTime
  description String
  fileUrl     String? // Vercel Blob URL when a receipt is attached
  fileName    String? // Original filename for download
  recurring   Boolean         @default(false)
  recurrence  String? // 'monthly' | 'yearly' | null

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([occurredAt])
  @@index([category])
}

enum ExpenseCategory {
  ai_tools
  hosting
  domains
  software
  hardware
  ads
  transport
  other
}

// ---------------------------------------------------------------
// Contract (Iter 4). Numbering: WVS000001 (no dash), transactional.
// `kind` discriminates the template/terms shape (see lib/validators/contract.ts).
// Manual signature via /sign/[token] (ADR sign flow): we store sha256(token),
// never the raw token. MAINTENANCE contracts spawn a Maintenance record on sign.
// No PVM. Single currency (EUR).
// ---------------------------------------------------------------
model Contract {
  id        String       @id @default(cuid())
  number    String       @unique // WVS000001
  kind      ContractKind @default(STAGED)
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Restrict)

  issuedAt DateTime
  status   ContractStatus @default(draft)

  // Структурированные данные шаблона (форма зависит от kind — см. contractTermsSchema)
  terms    Json
  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("EUR")

  // Подпись (sha256 raw token, TTL 7 дней, one-time consume)
  signTokenHash      String?   @unique // sha256(raw token)
  signTokenExpiresAt DateTime?
  signedAt           DateTime?
  signerName         String?
  signerIp           String?
  signerUserAgent    String?
  signatureUrl       String? // PNG в Vercel Blob — подпись ЗАКАЗЧИКА (по ссылке /sign)

  // Подпись ИСПОЛНИТЕЛЯ (моя) — ставится в приложении ("Подписать самому").
  // Не зависит от status и sign-токена: я подписываю свою колонку отдельно.
  providerSignedAt     DateTime?
  providerSignerName   String?
  providerSignatureUrl String? // PNG в Vercel Blob — подпись исполнителя

  // Импорт старого подписанного договора: если задано — это загруженный PDF,
  // PDF-роут отдаёт ИМЕННО этот файл, а не рендерит из terms (terms = плейсхолдер).
  // Переиспользуем существующий столбец — миграция не нужна.
  pdfUrl String?

  // MAINTENANCE-договор порождает запись Maintenance при подписании.
  maintenance Maintenance?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([status])
}

enum ContractKind {
  STAGED
  ADVANCE
  MAINTENANCE
}

enum ContractStatus {
  draft
  sent
  signed
  cancelled
}

// ---------------------------------------------------------------
// Proposal / КП (Iter 4). Numbering: WVP-001, transactional.
// JSON fields keep the template flexible. No PVM. Single currency (EUR).
// ---------------------------------------------------------------
model Proposal {
  id        String   @id @default(cuid())
  number    String   @unique // WVP-001
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Restrict)

  title      String
  status     ProposalStatus @default(draft)
  total      Decimal        @db.Decimal(12, 2)
  currency   String         @default("EUR")
  validUntil DateTime?

  // Структура КП (JSON — см. proposalSchema)
  scopeIncluded  Json // [{ title, description? }]
  scopeExcluded  Json? // [{ title, description? }]
  milestones     Json? // [{ name, deliverable?, dueLabel? }]
  paymentPlan    Json? // [{ label, amount, dueLabel? }]
  warranty       String?
  portfolioLinks Json? // [{ label, url }]

  pdfUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([status])
}

enum ProposalStatus {
  draft
  sent
  accepted
  declined
  revisions
}

// ---------------------------------------------------------------
// Maintenance (Iter 4 — promoted from Iter 5 to back MAINTENANCE contracts).
// projectId optional (support без проекта). contractId optional + unique
// (one Maintenance per signed MAINTENANCE contract). Monthly invoices linked
// via Invoice.maintenanceId + periodKey idempotency.
// ---------------------------------------------------------------
model Maintenance {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contractId String?   @unique
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  monthlyAmount Decimal           @db.Decimal(12, 2)
  currency      String            @default("EUR")
  includes      String?
  startedAt     DateTime
  nextInvoiceAt DateTime
  status        MaintenanceStatus @default(active)
  notes         String?

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([nextInvoiceAt])
  @@index([clientId])
  @@index([projectId])
}

enum MaintenanceStatus {
  active
  paused
  cancelled
  overdue_payment
}
