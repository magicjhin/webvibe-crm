# --- Database (Neon Postgres) ---
# Pooled connection — используется приложением
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct connection — используется Prisma migrate
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth.js v5 ---
# Случайная строка ≥ 32 символов: openssl rand -base64 32
AUTH_SECRET=""
# В dev: http://localhost:3000 ; в prod: https://<ваш-домен>
NEXTAUTH_URL="http://localhost:3000"

# --- Single admin user ---
# Email единственного пользователя CRM
ADMIN_EMAIL=""
# bcrypt-хеш пароля (cost factor 12): pnpm tsx scripts/hash-password.ts <password>
ADMIN_PASSWORD_HASH=""

# --- Vercel Blob storage (PDF, подписи, файлы) ---
BLOB_READ_WRITE_TOKEN=""

# --- Cron security ---
# Случайная строка для защиты /api/cron/* endpoints (Bearer token)
CRON_SECRET=""

# --- Опционально (Phase 2+) ---
# RESEND_API_KEY=""
# SENTRY_DSN=""
